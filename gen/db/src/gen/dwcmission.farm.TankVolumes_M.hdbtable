COLUMN TABLE dwcmission_farm_TankVolumes_M (
  createdAt TIMESTAMP,
  createdBy NVARCHAR(255),
  modifiedAt TIMESTAMP,
  modifiedBy NVARCHAR(255),
  TANK_ID NVARCHAR(30) NOT NULL,
  ID NVARCHAR(36),
  VOLUME DECIMAL,
  UOM NVARCHAR(3),
  TIME_STAMP TIMESTAMP,
  COMMENT NVARCHAR(50),
  SOURCE NVARCHAR(1) DEFAULT 'M',
  PRIMARY KEY(TANK_ID)
)