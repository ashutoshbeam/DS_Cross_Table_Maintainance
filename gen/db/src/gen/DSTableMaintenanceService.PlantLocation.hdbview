VIEW DSTableMaintenanceService_PlantLocation AS SELECT
  ZPLANT_LOCATION_0.createdAt,
  ZPLANT_LOCATION_0.createdBy,
  ZPLANT_LOCATION_0.modifiedAt,
  ZPLANT_LOCATION_0.modifiedBy,
  ZPLANT_LOCATION_0.PLANT,
  ZPLANT_LOCATION_0.ID,
  ZPLANT_LOCATION_0.COMPANY_CODE,
  ZPLANT_LOCATION_0.LOCATION,
  ZPLANT_LOCATION_0.LOCATION_TYPE,
  ZPLANT_LOCATION_0.REGION
FROM ztablemaintenance_farm_ZPLANT_LOCATION AS ZPLANT_LOCATION_0