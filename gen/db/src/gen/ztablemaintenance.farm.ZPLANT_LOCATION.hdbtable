COLUMN TABLE ztablemaintenance_farm_ZPLANT_LOCATION (
  createdAt TIMESTAMP,
  createdBy NVARCHAR(255),
  modifiedAt TIMESTAMP,
  modifiedBy NVARCHAR(255),
  PLANT NVARCHAR(4) NOT NULL,
  ID NVARCHAR(36),
  COMPANY_CODE NVARCHAR(4),
  LOCATION NVARCHAR(10),
  LOCATION_TYPE NVARCHAR(10),
  REGION NVARCHAR(10),
  PRIMARY KEY(PLANT)
)