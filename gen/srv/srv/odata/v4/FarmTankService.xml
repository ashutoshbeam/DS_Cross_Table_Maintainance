        <Property Name="TIME_STAMP" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="COMMENT" Type="Edm.String" MaxLength="50"/>
        <Property Name="SOURCE" Type="Edm.String" MaxLength="1" DefaultValue="M"/>
      </EntityType>
      <EntityType Name="PlantLocation">
        <Key>
          <PropertyRef Name="PLANT"/>
        </Key>
        <Property Name="PLANT" Type="Edm.String" MaxLength="4" Nullable="false"/>
        <Property Name="COMPANY_CODE" Type="Edm.String" MaxLength="4"/>
        <Property Name="LOCATION" Type="Edm.String" MaxLength="10"/>
        <Property Name="LOCATION_TYPE" Type="Edm.String" MaxLength="10"/>
        <Property Name="REGION" Type="Edm.String" MaxLength="10"/>
      </EntityType>
    </Schema>
  </edmx:DataServices>
