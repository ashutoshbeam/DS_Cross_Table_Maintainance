<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog title="{i18n>personalization}" stretch="{device>/system/phone}">
        <content>
            <List
                id="personalizationList"
                mode="MultiSelect"
                includeItemInSelection="true"
                items="{view>/columns}">
                <StandardListItem title="{view>name}" />
            </List>
        </content>
        <beginButton>
            <Button text="{i18n>apply}" type="Emphasized" press=".onPersonalizationApply" />
        </beginButton>
        <endButton>
            <Button text="{i18n>cancel}" press=".onPersonalizationCancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
