<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="createEditDialog"
        title="{view>/createEdit/title}"
        class="sapUiResponsivePadding--header sapUiResponsivePadding--content sapUiResponsivePadding--footer">
        <content>
            <VBox id="createEditFieldsBox" class="sapUiSmallMarginTopBottom" width="24rem" />
        </content>
        <beginButton>
            <Button
                type="Emphasized"
                text="{i18n>save}"
                press=".onSaveCreateEdit" />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                press=".onCancelCreateEdit" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
