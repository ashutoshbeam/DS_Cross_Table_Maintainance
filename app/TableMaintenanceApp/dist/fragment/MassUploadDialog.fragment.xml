<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified">
    <Dialog
        id="massUploadDialog"
        title="{i18n>massUploadDialogTitle}"
        contentWidth="72rem"
        contentHeight="36rem"
        class="sapUiResponsivePadding--header sapUiResponsivePadding--content sapUiResponsivePadding--footer">
        <content>
            <VBox class="sapUiSmallMarginTopBottom">
                <MessageStrip
                    text="{view>/upload/instructions}"
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginBottom" />

                <Toolbar design="Transparent">
                    <Button
                        icon="sap-icon://download"
                        text="{i18n>downloadTemplate}"
                        press=".onDownloadTemplate" />
                    <ToolbarSpacer />
                    <Text text="{view>/upload/fileName}" />
                </Toolbar>

                <unified:FileUploader
                    id="massUploadFile"
                    width="100%"
                    fileType="csv"
                    sameFilenameAllowed="true"
                    change=".onMassUploadFileChange" />

                <HBox class="sapUiSmallMarginTopBottom" justifyContent="SpaceBetween" alignItems="Center">
                    <Text text="{view>/upload/previewText}" />
                    <HBox visible="{= ${view>/upload/rows}.length > 0 }">
                        <ObjectStatus text="{i18n>totalRowsCount}: {view>/upload/totalCount}" state="None" class="sapUiTinyMarginEnd" />
                        <ObjectStatus text="{i18n>validRowsCount}: {view>/upload/validCount}" state="Success" class="sapUiTinyMarginEnd" />
                        <ObjectStatus text="{i18n>invalidRowsCount}: {view>/upload/invalidCount}" state="Error" />
                    </HBox>
                </HBox>

                <ScrollContainer width="100%" height="20rem" horizontal="true" vertical="true" visible="{= ${view>/upload/rows}.length > 0 }">
                    <Table
                        id="massUploadPreviewTable"
                        items="{view>/upload/rows}"
                        class="workspaceTable wideTable">
                        <columns>
                            <Column width="5rem"><Text text="{i18n>uploadStatusColumn}" /></Column>
                            <Column width="14rem"><Text text="{i18n>uploadMessageColumn}" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <ObjectStatus icon="{= ${view>_valid} ? 'sap-icon://sys-enter-2' : 'sap-icon://error' }" state="{= ${view>_valid} ? 'Success' : 'Error' }" />
                                    <Text text="{view>_message}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </ScrollContainer>
            </VBox>
        </content>
        <beginButton>
            <Button
                type="Emphasized"
                text="{i18n>upload}"
                enabled="{= ${view>/upload/rows}.length > 0 &amp;&amp; ${view>/upload/invalidCount} === 0 }"
                press=".onStartMassUpload" />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                press=".onCancelMassUpload" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
