<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        id="templateRoleSelectDialog"
        title="{i18n>templateRoleSelectLabel}"
        items="{view>/templateRoleItems}"
        search=".onTemplateRoleSelectSearch"
        cancel=".onTemplateRoleSelectCancel"
        confirm=".onTemplateRoleSelectConfirm">
        <StandardListItem
            title="{view>text}"
            description="{view>key}" />
    </SelectDialog>
</core:FragmentDefinition>
