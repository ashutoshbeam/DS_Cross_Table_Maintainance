<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        id="tableSelectDialog"
        title="{i18n>selectDialogTitle}"
        items="{view>/tableSelectItems}"
        search=".onTableSelectSearch"
        cancel=".onTableSelectCancel"
        confirm=".onTableSelectConfirm">
        <StandardListItem
            title="{view>text}"
            description="{view>key}" />
    </SelectDialog>
</core:FragmentDefinition>
