<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="multiUpdateDialog"
        title="{view>/multiUpdate/title}"
        class="sapUiResponsivePadding--header sapUiResponsivePadding--content sapUiResponsivePadding--footer">
        <content>
            <VBox class="sapUiSmallMarginTopBottom" width="24rem">
                <MessageStrip
                    text="{view>/multiUpdate/instructions}"
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginBottom" />
                <VBox id="multiUpdateFieldsBox" />
            </VBox>
        </content>
        <beginButton>
            <Button
                type="Emphasized"
                text="{i18n>apply}"
                press=".onApplyMultiUpdate" />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                press=".onCancelMultiUpdate" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
