<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout">
    <Dialog
        id="alterTableDialog"
        title="{i18n>alterTableDialogTitle}"
        contentWidth="900px"
        resizable="true">
        <content>
            <VBox class="sapUiSmallMargin">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout" columnsM="1" columnsL="1">
                    <f:content>
                        <Label text="{i18n>tableNameLabel}" />
                        <Text text="{view>/alterTable/tableName}" />
                    </f:content>
                </f:SimpleForm>

                <Title text="{i18n>fieldsTitle}" level="H3" class="sapUiTinyMarginTop sapUiTinyMarginBottom" />
                
                <Table
                    items="{view>/alterTable/fields}"
                    mode="Delete"
                    delete=".onRemoveAlterTableColumn">
                    <headerToolbar>
                        <OverflowToolbar>
                            <ToolbarSpacer />
                            <Button icon="sap-icon://add" text="{i18n>addField}" press=".onAddAlterTableColumn" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="10rem"><Text text="{i18n>fieldNameLabel}" /></Column>
                        <Column width="9rem"><Text text="{i18n>fieldSemanticTypeLabel}" /></Column>
                        <Column width="8rem"><Text text="{i18n>fieldTypeLabel}" /></Column>
                        <Column width="4rem"><Text text="{i18n>fieldLengthLabel}" /></Column>
                        <Column width="4rem"><Text text="{i18n>fieldScaleLabel}" /></Column>
                        <Column width="4rem"><Text text="{i18n>fieldPrimaryKeyLabel}" /></Column>
                        <Column width="4rem"><Text text="{i18n>fieldNotNullLabel}" /></Column>
                        <Column width="9rem"><Text text="{i18n>fieldReferenceTableLabel}" /></Column>
                        <Column width="9rem"><Text text="{i18n>fieldReferenceColumnLabel}" /></Column>
                        <Column width="9rem"><Text text="{i18n>fieldAliasesLabel}" /></Column>
                        <Column width="6rem"><Text text="{i18n>fieldDefaultLabel}" /></Column>
                        <Column width="8rem"><Text text="{i18n>fieldCommentLabel}" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Input value="{view>name}" editable="{= !${view>isExisting} }" />
                                <ComboBox value="{view>semanticType}" change=".onFieldSemanticTypeChange" items="{view>/semanticTypeSuggestions}">
                                    <core:Item key="{view>key}" text="{view>text}" />
                                </ComboBox>
                                <Select selectedKey="{view>type}">
                                    <core:Item key="VARCHAR" text="VARCHAR" />
                                    <core:Item key="NVARCHAR" text="NVARCHAR" />
                                    <core:Item key="INTEGER" text="INTEGER" />
                                    <core:Item key="DECIMAL" text="DECIMAL" />
                                    <core:Item key="BOOLEAN" text="BOOLEAN" />
                                    <core:Item key="DATE" text="DATE" />
                                    <core:Item key="TIMESTAMP" text="TIMESTAMP" />
                                    <core:Item key="DOUBLE" text="DOUBLE" />
                                </Select>
                                <Input value="{view>length}" type="Number" enabled="{= ${view>type} === 'NVARCHAR' || ${view>type} === 'VARCHAR' || ${view>type} === 'DECIMAL' }" />
                                <Input value="{view>scale}" type="Number" enabled="{= ${view>type} === 'DECIMAL' }" />
                                <CheckBox selected="{view>isPrimary}" enabled="false" />
                                <CheckBox selected="{view>isNotNull}" enabled="{= !${view>isPrimary} }" />
                                <Input value="{view>referenceTable}" />
                                <Input value="{view>referenceColumn}" />
                                <Input value="{view>aliases}" />
                                <Input value="{view>defaultValue}" />
                                <Input value="{view>comment}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <buttons>
            <Button text="{i18n>save}" type="Emphasized" press=".onSaveAlterTable" />
            <Button text="{i18n>cancel}" press=".onCancelAlterTable" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
