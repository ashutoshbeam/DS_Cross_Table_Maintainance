<mvc:View
    controllerName="dwcmission.plantlocationapp.controller.List"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>appTitle}" busy="{view>/busy}">
        <content>
            <VBox class="sapUiSmallMargin">
                <OverflowToolbar>
                    <Title text="{view>/tableTitle}" level="H2" />
                    <ToolbarSpacer />
                    <Label text="{i18n>tableSelectLabel}" />
                    <Select
                        width="16rem"
                        selectedKey="{view>/selectedTable}"
                        change=".onTableChange"
                        items="{
                            path: 'view>/tables'
                        }">
                        <core:Item key="{view>name}" text="{view>label}" />
                    </Select>
                </OverflowToolbar>
                <OverflowToolbar>
                    <Button
                        icon="sap-icon://add"
                        type="Emphasized"
                        tooltip="{i18n>create}"
                        enabled="{= !!${view>/selectedTable} }"
                        press=".onCreate" />
                    <Button
                        icon="sap-icon://edit"
                        tooltip="{i18n>edit}"
                        enabled="{= !!${view>/selectedTable} &amp;&amp; ${view>/selectedCount} === 1 }"
                        press=".onEdit" />
                    <Button
                        icon="sap-icon://delete"
                        text="{i18n>delete}"
                        enabled="{= !!${view>/selectedTable} &amp;&amp; ${view>/selectedCount} > 0 }"
                        press=".onDelete" />
                    <Button
                        icon="sap-icon://history"
                        text="{i18n>changeHistoryButton}"
                        enabled="{= !!${view>/selectedTable} &amp;&amp; ${view>/selectedCount} === 1 }"
                        press=".onOpenChangeHistory" />
                    <Button
                        icon="sap-icon://multi-select"
                        text="{i18n>multiUpdate}"
                        enabled="{= !!${view>/selectedTable} &amp;&amp; ${view>/selectedCount} > 1 }"
                        press=".onOpenMultiUpdate" />
                    <Button
                        icon="sap-icon://upload"
                        text="{i18n>massUpload}"
                        enabled="{= !!${view>/selectedTable} }"
                        press=".onOpenMassUpload" />
                    <ToolbarSpacer />
                    <Text text="{i18n>selectedCountLabel}: {view>/selectedCount}" />
                    <ToolbarSeparator />
                    <SearchField
                        width="18rem"
                        placeholder="{i18n>searchPlaceholder}"
                        liveChange=".onSearch" />
                    <Button
                        icon="sap-icon://refresh"
                        text="{i18n>refresh}"
                        press=".onRefresh" />
                </OverflowToolbar>
                <Table
                    id="plantTable"
                    width="auto"
                    growing="true"
                    growingScrollToLoad="true"
                    mode="MultiSelect"
                    selectionChange=".onSelectionChange"
                    noDataText="{i18n>noTableData}" />
            </VBox>
        </content>

        <dependents>
            <core:Fragment fragmentName="dwcmission.plantlocationapp.fragment.CreateEditDialog" type="XML" />
            <core:Fragment fragmentName="dwcmission.plantlocationapp.fragment.MultiUpdateDialog" type="XML" />
            <core:Fragment fragmentName="dwcmission.plantlocationapp.fragment.MassUploadDialog" type="XML" />
        </dependents>
    </Page>
</mvc:View>
